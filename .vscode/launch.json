{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Example (build & run)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceRoot}/node_modules/.bin/electron",
      "args": ["./example/main.js"],
      "preLaunchTask": "npm: build",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Build Only",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "args": ["run", "build"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Dev (watch)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "args": ["run", "dev"],
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
