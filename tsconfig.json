{
  "compilerOptions": {
    "lib": ["ES2022", "DOM"],
    "baseUrl": "./src",
    "paths": {
      "base/*": ["./base/*"]
    },
    "module": "CommonJS",
    "target": "ES2021",
    "declaration": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["esbuild-plugin-raw/client"]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "**/node_modules/*"
  ]
}